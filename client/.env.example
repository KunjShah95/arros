# API Configuration
# In development, these are handled by Vite proxy
# In production, set these to your deployed API URL

# API Base URL (optional - defaults to relative /api path)
# VITE_API_URL=https://api.yourdomain.com/api

# WebSocket URL (optional - auto-detected from window.location)
# VITE_WS_URL=wss://api.yourdomain.com/ws
